@page "/recipes"

<PageTitle>Recipes | Maasi</PageTitle>

<section class="recipes-hero" aria-labelledby="recipes-heading">
    <div class="recipes-hero-copy">
        <p class="eyebrow">Recipes</p>
        <h1 id="recipes-heading">Food I want to make again</h1>
        <p>
            A starter collection of simple meals with ingredients, timing, and step-by-step notes.
            This page can grow into your own cookbook as you add favorites.
        </p>
    </div>
</section>

<section class="recipe-list" aria-label="Recipe list">
    @foreach (var recipe in RecipeItems)
    {
        <article class="recipe-card" style="--accent: @recipe.Accent">
            <header class="recipe-card-header">
                <div>
                    <p class="recipe-category">@recipe.Category</p>
                    <h2>@recipe.Name</h2>
                </div>
                <span class="difficulty">@recipe.Difficulty</span>
            </header>

            <p class="description">@recipe.Description</p>

            <dl class="recipe-meta">
                <div>
                    <dt>Time</dt>
                    <dd>@recipe.Time</dd>
                </div>
                <div>
                    <dt>Serves</dt>
                    <dd>@recipe.Servings</dd>
                </div>
            </dl>

            <div class="recipe-columns">
                <section aria-label="@($"{recipe.Name} ingredients")">
                    <h3>Ingredients</h3>
                    <ul class="ingredient-list">
                        @foreach (var ingredient in recipe.Ingredients)
                        {
                            <li>@ingredient</li>
                        }
                    </ul>
                </section>

                <section aria-label="@($"{recipe.Name} steps")">
                    <h3>Steps</h3>
                    <ol class="step-list">
                        @for (var i = 0; i < recipe.Steps.Length; i++)
                        {
                            <li>
                                <span>@(i + 1)</span>
                                @recipe.Steps[i]
                            </li>
                        }
                    </ol>
                </section>
            </div>
        </article>
    }
</section>

